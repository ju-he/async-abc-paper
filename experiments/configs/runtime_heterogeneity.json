{
  "experiment_name": "runtime_heterogeneity",
  "benchmark": {
    "name": "lotka_volterra",
    "observed_data_seed": 42,
    "T_max": 30.0,
    "x0": 50,
    "y0": 100,
    "true_theta1": 0.5,
    "true_theta2": 0.025,
