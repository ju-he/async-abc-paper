{
  "experiment_name": "runtime_heterogeneity",
  "benchmark": {
    "name": "gaussian_mean",
    "observed_data_seed": 42,
    "n_obs": 100,
    "true_mu": 0.0,
    "sigma_obs": 1.0,
    "prior_low": -5.0,
    "prior_high": 5.0
  },
  "methods": ["async_propulate_abc", "abc_smc_baseline"],
  "inference": {
    "max_simulations": 500000,
    "n_workers": 48,
    "k": 100,
    "tol_init": 5.0,
    "n_generations": 1000,
    "max_wall_time_s": 60.0,
    "scheduler_type": "acceptance_rate",
    "perturbation_scale": 0.8,
    "propulate_budget_mode": "total_simulations"
  },
  "execution": {
    "n_replicates": 5,
    "base_seed": 0
  },
  "heterogeneity": {
    "distribution": "lognormal",
    "mu": 0.0,
    "sigma_levels": [0.0, 0.5, 1.0, 1.5, 2.0]
  },
  "plots": {
    "idle_fraction": true,
    "throughput_over_time": true,
    "idle_fraction_comparison": true,
    "gantt": true,
    "quality_by_sigma": true
  },
  "paper": {
    "experiment_role": "hpc_performance",
    "stop_policy": "fixed_walltime",
    "method_comparison_roles": {
      "async_propulate_abc": "proposed_async_method",
      "abc_smc_baseline": "main_sync_baseline"
    }
  }
}
